{
    "name": "obsidian-oxfmt",
    "version": "1.0.0",
    "description": "Format notes and code in your Obsidian vault with oxfmt on save.",
    "keywords": [
        "formatter",
        "obsidian",
        "obsidian-plugin",
        "oxc",
        "oxfmt"
    ],
    "license": "0-BSD",
    "type": "module",
    "main": "main.js",
    "scripts": {
        "dev": "node esbuild.config.mjs",
        "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
        "lint": "oxlint",
        "test": "node --test",
        "format": "oxfmt --write",
        "format:check": "oxfmt --check",
        "security": "opengrep scan --error --config p/typescript --config p/security-audit ."
    },
    "devDependencies": {
        "@types/node": "^22.15.17",
        "esbuild": "0.25.5",
        "obsidian": "latest",
        "typescript": "^5.8.3"
    },
    "aube": {
        "allowBuilds": {
            "esbuild": true
        }
    }
}
